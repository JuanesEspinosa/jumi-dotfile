[
  {
    "layer": "top",
    "position": "top",
    "height": 36,
    "spacing": 4,
    "margin-top": 6,
    "margin-left": 10,
    "margin-right": 10,

    "modules-left": [
      "hyprland/workspaces",
      "hyprland/window"
    ],
    "modules-center": [
      "clock"
    ],
    "modules-right": [
      "custom/project",
      "pulseaudio",
      "network",
      "battery",
      "tray"
    ],

    "hyprland/workspaces": {
      "format": "{icon}",
      "format-icons": {
        "1": "َ°ˆ¹",
        "2": "َ°¨‍",
        "3": "َ°–ں",
        "4": "َ°†¼",
        "5": "َ°­¹",
        "urgent": "",
        "active": "",
        "default": ""
      },
      "persistent-workspaces": {
        "*": [1, 2, 3, 4, 5]
      }
    },

    "hyprland/window": {
      "format": "{}",
      "max-length": 40
    },

    "clock": {
      "format": "َ°¥” {:%H:%M}",
      "format-alt": "َ°ƒ¶ {:%A, %d %B %Y}",
      "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
    },

    "battery": {
      "states": {
        "warning": 30,
        "critical": 15
      },
      "format": "{icon} {capacity}%",
      "format-charging": "َ°‚„ {capacity}%",
      "format-plugged": "َ°ڑ¥ {capacity}%",
      "format-icons": ["َ°پ؛","َ°پ»","َ°پ¼","َ°پ½","َ°پ¾","َ°پ؟","َ°‚€","َ°‚پ","َ°‚‚","َ°پ¹"]
    },

    "network": {
      "format-wifi": "َ°¤¨ {signalStrength}%",
      "format-ethernet": "َ°ˆ€ {ifname}",
      "format-disconnected": "َ°¤­ Sin red",
      "tooltip-format-wifi": "{essid} â€” {signalStrength}% â€” {ipaddr}",
      "on-click": "nm-connection-editor",
      "interval": 10
    },

    "pulseaudio": {
      "format": "{icon} {volume}%",
      "format-muted": "َ°‌ں",
      "format-icons": {
        "default": ["َ°•؟", "َ°–€", "َ°•¾"]
      },
      "on-click": "pavucontrol"
    },

    "tray": {
      "spacing": 8
    },

    "custom/project": {
      "exec": "~/.config/waybar/modules/project-status.sh",
      "interval": 30,
      "format": "َ°ڈ— {}",
      "tooltip": true
    }
  }
]
